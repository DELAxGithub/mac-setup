{
  "permissions": {
    "allow": [
      "Edit",
      "Write",
      "Bash(git *)",
      "Bash(git push:*)",
      "Bash(git push)",
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(deno *)",
      "Bash(xcodebuild *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(ffmpeg *)",
      "Bash(ffprobe *)",
      "Bash(curl *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(op vault list)",
      "Bash(delegate-task:*)",
      "Bash(PATH=\"$HOME/.deno/bin:$PATH\" deployctl deploy:*)",
      "mcp__pencil"
    ],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "circleback@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-push-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/pre-commit-moderate.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"承認待ち\" with title \"Claude Code\" sound name \"Glass\"'",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"入力待ち\" with title \"Claude Code\" sound name \"Pop\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-start-cold-loader.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.claude/hooks/session-end-state-update.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "effortLevel": "xhigh",
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true,
  "autoMode": {
    "allow": [
      "$defaults",
      "git push including pushes to default branches (main/master) — user has explicitly authorized direct main pushes for solo-dev workflow"
    ]
  }
}
